<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingStart="@dimen/kd_space_400"
    android:paddingEnd="@dimen/kd_space_400"
    android:paddingTop="@dimen/kd_space_300"
    android:paddingBottom="@dimen/kd_space_300">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="输入"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/kd_font_extra_large"
        android:textStyle="bold" />

    <!-- 多行时由代码按可见行数设置 maxHeight，内容超出在框内滚动，避免挡住底部按钮 -->
    <EditText
        android:id="@+id/etInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/kd_space_200"
        android:background="@drawable/bg_input_radius"
        android:paddingHorizontal="@dimen/kd_space_400"
        android:paddingVertical="@dimen/kd_space_300"
        android:gravity="top|start"
        android:scrollbars="vertical"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="@dimen/kd_font_base" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/kd_space_400"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnNegative"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingStart="@dimen/kd_space_400"
            android:paddingEnd="@dimen/kd_space_400"
            android:paddingTop="@dimen/kd_space_100"
            android:paddingBottom="@dimen/kd_space_100"
            android:text="取消"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/kd_font_base" />

        <TextView
            android:id="@+id/btnPositive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/kd_space_200"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingStart="@dimen/kd_space_400"
            android:paddingEnd="@dimen/kd_space_400"
            android:paddingTop="@dimen/kd_space_100"
            android:paddingBottom="@dimen/kd_space_100"
            android:text="确定"
            android:textColor="@color/kd_public_normal"
            android:textSize="@dimen/kd_font_base" />
    </LinearLayout>

</LinearLayout>
