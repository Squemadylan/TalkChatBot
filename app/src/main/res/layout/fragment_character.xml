<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/kd_space_400"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="@dimen/kd_touch_min"
            android:layout_weight="1"
            android:hint="搜索角色..."
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/bg_input_radius"
            android:maxLength="500"
            android:paddingStart="@dimen/kd_space_400"
            android:paddingEnd="@dimen/kd_space_400"
            android:singleLine="true"
            android:textSize="@dimen/kd_font_base"
            android:layout_marginEnd="@dimen/kd_space_300"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilter"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/kd_touch_min"
            android:layout_marginEnd="@dimen/kd_space_300"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="@dimen/kd_space_400"
            android:paddingEnd="@dimen/kd_space_400"
            android:text="筛选"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/kd_font_base"
            app:cornerRadius="@dimen/kd_radius_200"
            app:strokeColor="@color/kd_input_stroke"
            app:strokeWidth="1dp" />

        <ImageButton
            android:id="@+id/btnAddCharacter"
            android:layout_width="@dimen/kd_input_height"
            android:layout_height="@dimen/kd_input_height"
            android:background="@drawable/bg_button_radius"
            android:contentDescription="添加角色"
            android:padding="@dimen/kd_space_250"
            android:scaleType="centerInside"
            android:src="@drawable/ic_add"
            app:tint="@color/text_on_primary" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/kd_space_400"
        android:clipToPadding="false"/>

</LinearLayout>
