<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/kd_space_400">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_radius"
            android:orientation="vertical"
            android:padding="@dimen/kd_space_500"
            android:layout_marginBottom="@dimen/kd_space_400">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="个人设置"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/kd_font_xx_large"
                android:textStyle="bold"
                android:paddingBottom="@dimen/kd_space_200"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="资料和设定在这里"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/kd_font_base"
                android:paddingBottom="@dimen/kd_space_500"/>

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:paddingBottom="@dimen/kd_space_500">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="@dimen/kd_avatar_display"
                    android:layout_height="@dimen/kd_avatar_display"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                    app:strokeColor="@color/kd_line_regular"
                    app:strokeWidth="1dp" />

                <ImageButton
                    android:id="@+id/btnAvatarEdit"
                    android:layout_width="@dimen/kd_avatar_edit_btn"
                    android:layout_height="@dimen/kd_avatar_edit_btn"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="@dimen/kd_space_200"
                    android:background="@drawable/bg_avatar_edit"
                    android:contentDescription="更换头像"
                    android:padding="@dimen/kd_space_200"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_image"
                    app:tint="@color/kd_public_normal" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_person"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="用户名"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="用户"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_document"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="用户人设"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                    <TextView
                        android:id="@+id/tvUserPersona"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="补充你的身份和设定"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_base"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_radius"
            android:orientation="vertical"
            android:padding="@dimen/kd_space_500"
            android:layout_marginBottom="@dimen/kd_space_400">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="通用设置"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/kd_font_xx_large"
                android:textStyle="bold"
                android:paddingBottom="@dimen/kd_space_200"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="主题设置"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/kd_font_base"
                android:paddingBottom="@dimen/kd_space_500"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_sun"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="深色模式"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="开启后界面将切换为深色主题"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <Switch
                    android:id="@+id/switchDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_radius"
            android:orientation="vertical"
            android:padding="@dimen/kd_space_500"
            android:layout_marginBottom="@dimen/kd_space_400">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="聊天界面设置"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/kd_font_xx_large"
                android:textStyle="bold"
                android:paddingBottom="@dimen/kd_space_200"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="聊天显示和辅助功能"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/kd_font_base"
                android:paddingBottom="@dimen/kd_space_500"/>

            <LinearLayout
                android:id="@+id/llBackgroundSetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_image"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="背景设置"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:id="@+id/tvBackgroundSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="未设置（使用默认背景）"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llBubbleSetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_chat"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="气泡设置"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:id="@+id/tvBubbleSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="当前：默认"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llVoiceSetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_volume"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="语音设置"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="自动播放已关闭"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llMemorySetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/kd_icon_large"
                        android:layout_height="@dimen/kd_icon_large"
                        android:src="@drawable/ic_memory"
                        android:tint="@color/pink_primary"
                        android:layout_marginEnd="@dimen/kd_space_300"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="记忆设置"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/kd_font_middle"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="请求大模型时附带的历史消息条数（0–10）"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/kd_font_small"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMemoryStrengthValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textColor="@color/pink_primary"
                        android:textSize="@dimen/kd_font_extra_large"
                        android:textStyle="bold"
                        android:minWidth="@dimen/kd_space_800"
                        android:gravity="end"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekMemoryContext"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/kd_space_300"
                    android:max="10"
                    android:progress="5" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llChatAvatarSetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_group"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="对话显示头像"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="关闭后双方头像均隐藏"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switchChatShowAvatars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:checked="true"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llReplySetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_document"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="回复设置"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:id="@+id/tvReplySummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="标准：自然平衡，不额外约束"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llImageSetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_image"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="配图设置"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="配图已禁用"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llStatusBarSetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="状态栏设置"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:id="@+id/tvStatusBarSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="默认：保留系统状态栏间距，图标跟随主题"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_radius"
            android:orientation="vertical"
            android:padding="@dimen/kd_space_500">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="关于与帮助"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/kd_font_xx_large"
                android:textStyle="bold"
                android:paddingBottom="@dimen/kd_space_200"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="版本和反馈入口"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/kd_font_base"
                android:paddingBottom="@dimen/kd_space_500"/>

            <LinearLayout
                android:id="@+id/llBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_document"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="备份与恢复"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="导出角色、个人资料与 API 配置，或从备份恢复"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llCheckUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_sync"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="检查更新"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:id="@+id/tvVersion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="当前版本: v1.0.0"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llManualUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/kd_space_300"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_web"
                    android:tint="@color/pink_primary"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/update_manual_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_middle"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/update_manual_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/kd_icon_middle"
                    android:layout_height="@dimen/kd_icon_middle"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>