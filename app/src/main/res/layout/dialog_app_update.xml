<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/kd_space_400"
    android:paddingEnd="@dimen/kd_space_400"
    android:paddingTop="@dimen/kd_space_200"
    android:paddingBottom="@dimen/kd_space_100">

    <TextView
        android:id="@+id/tvUpdateMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/kd_font_base"
        android:lineSpacingMultiplier="1.2" />

    <ProgressBar
        android:id="@+id/progressUpdate"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/kd_space_400"
        android:max="100"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvUpdateProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/kd_space_200"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/kd_font_small"
        android:visibility="gone" />

</LinearLayout>
