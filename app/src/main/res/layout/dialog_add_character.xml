<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_sheet_top_rounded">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/kd_touch_min"
        android:paddingStart="@dimen/kd_space_200"
        android:paddingEnd="@dimen/kd_space_200">

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="@dimen/kd_touch_min"
            android:layout_height="@dimen/kd_touch_min"
            android:layout_gravity="start|center_vertical"
            android:gravity="center"
            android:text="×"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/kd_font_xxx_large"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="关闭" />

        <TextView
            android:id="@+id/tvSheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="创建角色"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/kd_font_extra_large"
            android:textStyle="bold" />
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingStart="@dimen/kd_space_400"
        android:paddingEnd="@dimen/kd_space_400"
        android:paddingBottom="@dimen/kd_space_400">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/kd_space_300"
                android:layout_marginBottom="@dimen/kd_space_400">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivDialogAvatar"
                    android:layout_width="@dimen/kd_avatar_create_sheet"
                    android:layout_height="@dimen/kd_avatar_create_sheet"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                    app:strokeColor="@color/kd_line_regular"
                    app:strokeWidth="1dp" />

                <ImageButton
                    android:id="@+id/btnRandomAvatar"
                    android:layout_width="@dimen/kd_avatar_edit_btn"
                    android:layout_height="@dimen/kd_avatar_edit_btn"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="@dimen/kd_space_200"
                    android:background="@drawable/bg_circle_orange"
                    android:contentDescription="随机头像"
                    android:padding="@dimen/kd_space_200"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_sync"
                    app:tint="@color/kd_color_white" />

                <ImageButton
                    android:id="@+id/btnPickDialogAvatar"
                    android:layout_width="@dimen/kd_avatar_edit_btn"
                    android:layout_height="@dimen/kd_avatar_edit_btn"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="@dimen/kd_space_200"
                    android:background="@drawable/bg_avatar_edit"
                    android:contentDescription="从相册选择头像"
                    android:padding="@dimen/kd_space_200"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_image"
                    app:tint="@color/kd_public_normal" />
            </FrameLayout>

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/kd_space_500"
                android:background="@drawable/bg_input_radius"
                android:gravity="center"
                android:hint="新角色"
                android:inputType="textPersonName"
                android:maxLength="500"
                android:maxLines="1"
                android:paddingHorizontal="@dimen/kd_space_400"
                android:paddingVertical="@dimen/kd_space_300"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="@dimen/kd_font_xx_large"
                android:textStyle="bold" />

            <include
                android:id="@+id/rowTags"
                layout="@layout/view_character_setting_row" />

            <include
                android:id="@+id/rowDescription"
                layout="@layout/view_character_setting_row" />

            <include
                android:id="@+id/rowOpening"
                layout="@layout/view_character_setting_row" />

            <LinearLayout
                android:id="@+id/rowLongTermMemory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_memory"
                    android:tint="@color/pink_primary"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="永久记忆"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_base"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="开启后自动压缩对话历史生成摘要"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchLongTermMemory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/kd_space_200"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowAutoRead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="@dimen/kd_touch_min"
                android:padding="@dimen/kd_space_400"
                android:background="@drawable/bg_input_radius"
                android:layout_marginBottom="@dimen/kd_space_300"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/kd_icon_large"
                    android:layout_height="@dimen/kd_icon_large"
                    android:src="@drawable/ic_mic"
                    android:tint="@color/pink_primary"
                    android:layout_marginEnd="@dimen/kd_space_300"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="自动朗读"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/kd_font_base"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="角色回复后自动朗读文字"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/kd_font_small"/>

                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoRead"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/kd_space_200"/>

            </LinearLayout>

            <include
                android:id="@+id/rowAlternate"
                layout="@layout/view_character_setting_row" />

            <include
                android:id="@+id/rowExamples"
                layout="@layout/view_character_setting_row" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="@dimen/kd_space_1200"
        android:layout_marginStart="@dimen/kd_space_400"
        android:layout_marginEnd="@dimen/kd_space_400"
        android:layout_marginBottom="@dimen/kd_space_500"
        android:background="@drawable/bg_button_radius"
        android:text="创建角色"
        android:textColor="@color/text_on_primary"
        android:textSize="@dimen/kd_font_middle"
        android:textStyle="bold" />

</LinearLayout>
